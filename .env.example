# Supabase project URL (қауіпсіз, браузерде қолданылады)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon public key (қауіпсіз, браузерде қолданылады)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role key — ТЕК сервер жағында (API routes). Браузерге ЕШҚАШАН шықпайды.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Міндетті емес: қойылса, /admin беті осы code арқылы ашылады.
# Қойылмаса, ADMIN_FULL_NAME user-інің 4 сандық коды қолданылады.
ADMIN_ACCESS_CODE=your-admin-code
ADMIN_FULL_NAME=aqarys
