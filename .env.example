# Supabase project URL (қауіпсіз, браузерде қолданылады)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon public key (қауіпсіз, браузерде қолданылады)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role key — ТЕК сервер жағында (API routes). Браузерге ЕШҚАШАН шықпайды.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
